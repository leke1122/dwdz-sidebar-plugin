{
  "name": "dwdz-sidebar-plugin",
  "version": "0.0.99",
  "private": true,
  "type": "module",
  "output": "dist",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:block": "node ./scripts/build-block.mjs",
    "verify:block-dist": "node ./scripts/verify-block-dist.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "self-check": "node ./scripts/self-check.mjs",
    "release:version": "node ./scripts/read-plugin-version.mjs",
    "release:upload:block": "node ./scripts/release-upload-block.mjs",
    "release:vercel:prod": "vercel deploy --prod --yes",
    "release:ship:test": "npm run release:vercel:prod && npm run release:upload:block"
  },
  "dependencies": {
    "@lark-opdev/block-bitable-api": "^0.4.1-alpha.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  }
}
